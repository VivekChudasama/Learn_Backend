doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title title=title 
    body 
        h1= message
        p This content is generated using a Pug template.

        h2 List of Items
        ul
        each item in items
            li= item